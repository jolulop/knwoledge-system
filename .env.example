# Copy to .env and fill in as needed. Do not commit .env.
KNOWLEDGE_SYSTEM_HOME=/home/jolulop/code/knowledge-system
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
APP_HOST=127.0.0.1
APP_PORT=18000
# NOTE: app-level auth is NOT implemented (loopback-only, ADR-0009; auth+CSRF is Phase-8-class future
# work). There is no APP_AUTH_TOKEN setting — nothing reads it. Do not expose the app off loopback.
JOBS_DATABASE_URL=sqlite:///db/jobs.sqlite
# Derived retrieval indexes live under indexes/ (ADR-0032 §7), not db/. The keyword index is
# SQLite FTS5 at indexes/keyword/keyword.sqlite; the vector backend (LanceDB) arrives in Phase 4d.
KEYWORD_BACKEND=sqlite-fts5
VECTOR_BACKEND=
# Embedding backend. Two options:
#
# (A) DEFAULT / GPU — in-process FlagEmbedding + PyTorch CUDA (ADR-0053). BAAI/bge-m3 runs on the GPU
#     in-process (TEI/Candle falls back to CPU on the RTX 5090). GPU stack is an out-of-lock install:
#     torch from the CUDA 12.8 wheel index, then FlagEmbedding (see docs/Environment Setup §14.1). Validate with
#     `uv run python scripts/check_embedding.py`. When EMBEDDING_PROVIDER=flagembedding_bge_m3 and
#     EMBEDDING_DEVICE=cuda, the app validates CUDA + loads the model once at startup (fail-fast);
#     non-vector app roles (ingest/review/lint) never import Torch.
EMBEDDING_PROVIDER=flagembedding_bge_m3
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_USE_FP16=true
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_DIMENSION=1024
EMBEDDING_DISTANCE_METRIC=cosine
# EMBEDDING_CACHE_DIR unset → FlagEmbedding/HF default cache (~/.cache/huggingface). Set a project path
# (must be writable) only if you want a repo-local model cache.
EMBEDDING_CACHE_DIR=
#
# (B) CPU FALLBACK / HTTP seam (ADR-0033) — a local OpenAI-compatible /embeddings server you run
#     (TEI/vLLM/Ollama). local_http base_url must be loopback/LAN; EMBEDDING_MODEL_REF is the staleness
#     identity — bump it on any model/quant/version change. Cloud is opt-in only: provider=cloud_* AND
#     EMBEDDING_ALLOW_CLOUD=true AND EMBEDDING_API_KEY (a dedicated key, never reusing OPENAI_API_KEY).
#     To use it: EMBEDDING_PROVIDER=local_http, set EMBEDDING_BASE_URL + EMBEDDING_MODEL_REF.
# EMBEDDING_PROVIDER=local_http
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_REF=
EMBEDDING_API_KEY=
EMBEDDING_ALLOW_CLOUD=
EMBEDDING_ALLOW_MODEL_MISMATCH=
# Phase 2 extraction (defaults shown)
EXTRACT_MAX_FILE_MB=50
EXTRACT_TIMEOUT_S=120
EXTRACT_CHUNK_TARGET_CHARS=1000
EXTRACT_CHUNK_MAX_CHARS=2000
# Phase 3 wiki generation (defaults shown)
WIKI_SUMMARY_MAX_CHARS=320
WIKI_SUMMARY_MIN_CHARS=40
# Phase 3.5 enrichment (tier -> provider:model_id; defaults are examples, not normative)
ENRICH_MODEL_LIGHT=anthropic:claude-haiku-4-5
ENRICH_MODEL_STANDARD=anthropic:claude-sonnet-4-6
ENRICH_MODEL_HEAVY=anthropic:claude-opus-4-8
ENRICH_MAX_TOKENS=4096
# Phase 5 query answering (POST /query). Synthesis model_ref; defaults to the standard tier.
# Without it (and a provider credential) /query returns 503; GET /search stays key-free.
QUERY_MODEL=anthropic:claude-sonnet-4-6
# Local OpenAI-compatible server base URL (Ollama/vLLM/LM Studio); required for local: refs
ENRICH_LOCAL_BASE_URL=
# OpenAI base URL override (optional)
OPENAI_BASE_URL=
