.env
__pycache__/
*.pyc
.venv/
node_modules/
.DS_Store
Thumbs.db
backups/*.zip
# Windows mark-of-the-web metadata (WSL)
*:Zone.Identifier
# Distributable docs archive (docs are tracked under docs/)
knowledge-system-docs-*.zip
# Derived retrieval indexes are regenerable local runtime state (ADR-0014/0032 §7), rebuilt
# from chunks + wiki by scripts/reindex_keyword.py (keyword) and the vector reindexer. They are
# never committed; the keyword index is not even backed up (cheap full rebuild). Keep .gitkeeps.
indexes/keyword/keyword.sqlite*
indexes/vector/*
!indexes/vector/.gitkeep
# Transient temp/backup dirs from the atomic vector-index swap (reindex_vector.py).
indexes/vector.tmp/
indexes/vector.bak/
# All SQLite databases under db/ are durable local runtime state, never committed: the
# job state (ADR-0008), the LLM response cache (ADR-0027), and the authoritative semantic
# graph (ADR-0030). They are made durable by the backup mechanism (scripts/backup.py), not
# git. The keyword index moved to indexes/ (ADR-0032 §7). Keep db/.gitkeep tracked.
db/*.sqlite
# Phase 2 normalized layer is regenerable local runtime state (ADR-0011): the
# per-source markdown, chunks, tables, and extraction logs are rebuilt from raw
# sources by scripts/extract_sources.py and are not committed. Keep the .gitkeeps.
normalized/markdown/*.md
normalized/chunks/*.jsonl
normalized/tables/*/
normalized/extraction_logs/*.json
# Phase 3.5 enrichment artifacts (summary/tags, claims, per-claim records) are derived
# state regenerated from the response cache (ADR-0025/0027), never committed.
normalized/enrichment/
# Phase 3 wiki layer is mutable local data, not code (ADR-0014): generated Source
# pages, the regenerated index.md, and the append-only log.md are reproduced by the
# pipeline and made durable by the backup mechanism, never committed. Keep .gitkeeps.
wiki/index.md
wiki/log.md
wiki/Sources/*.md
wiki/Concepts/*.md
wiki/Claims/*.md
wiki/Entities/*.md
wiki/People/*.md
wiki/Organizations/*.md
wiki/Projects/*.md
wiki/Tags/*.md
wiki/Synthesis/*.md
wiki/Queries/*.md
wiki/.obsidian/
# Inbox is transient staging for scans; keep its contents out of git.
raw/inbox/*
!raw/inbox/.gitkeep
# Manifests are local runtime state: authoritative on disk, not committed.
raw/manifests/*.json
!raw/manifests/.gitkeep
# Uncomment if these raw files should also be kept out of git.
# raw/permanent/*
# raw/ephemeral/*
